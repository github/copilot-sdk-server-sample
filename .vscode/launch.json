{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "Launch Frontend",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "runtimeExecutable": "${workspaceFolder}/app/node_modules/.bin/tsx",
            "program": "${workspaceFolder}/app/src/index.ts",
            "cwd": "${workspaceFolder}/app",
            "console": "integratedTerminal"
        }
    ]
}